{
  "name": "boltcallApiKey",
  "label": "Boltcall API Key",
  "type": "apiKey",
  "help": "Create a key in Boltcall Dashboard > Settings > API Keys. It starts with bc_.",
  "parameters": [
    {
      "name": "apiKey",
      "type": "password",
      "label": "API Key",
      "required": true
    }
  ],
  "test": {
    "url": "/api-me",
    "method": "GET",
    "headers": {
      "Authorization": "Bearer {{connection.apiKey}}"
    }
  }
}
